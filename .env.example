# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/review_platform?schema=public"

# App
APP_ORIGIN="http://localhost:3000"
APP_NAME="Clarify"

# 2GIS
TWOGIS_GEOCODER_API_KEY=""
NEXT_PUBLIC_TWOGIS_MAPGL_API_KEY=""

# Mail mode:
# - console  -> печатает OTP код в терминал (локальная разработка, стабильно)
# - smtp     -> реальная отправка через SMTP (prod/staging)
# - disabled -> ничего не отправляет (например тесты)
MAIL_MODE="console"

# SMTP (нужно только если MAIL_MODE=smtp)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your.smtp@gmail.com"
SMTP_PASS="YOUR_APP_PASSWORD"
MAIL_FROM="Clarify <your.smtp@gmail.com>"

# Email verification
EMAIL_CODE_PEPPER="CHANGE_ME_LONG_RANDOM_SECRET"
EMAIL_CODE_TTL_MIN=10