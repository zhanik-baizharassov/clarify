generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  COMPANY
  ADMIN
}

enum ReviewStatus {
  PUBLISHED
  PENDING
  REJECTED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String    @id @default(cuid())
  firstName        String?
  lastName         String?
  nickname         String?   @unique
  email            String    @unique
  phone            String?   @unique
  passwordHash     String
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  profileEditCount Int       @default(0)
  profileEditedAt  DateTime?
  emailVerifiedAt  DateTime?
  blockedUntil     DateTime?
  blockReason      String?

  sessions           Session[]
  emailVerifications EmailVerification[]
  companies          Company[]           @relation("CompanyOwner")
  reviews            Review[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Company {
  id      String @id @default(cuid())
  name    String
  ownerId String @unique

  bin          String?   @unique
  address      String?
  blockedUntil DateTime?
  blockReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User      @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  claims  Claim[]
  replies ReviewReply[]
  places  Place[]

  @@index([ownerId])
}

model PendingCompanySignup {
  id               String   @id @default(cuid())
  companyName      String
  bin              String   @unique
  city             String
  phone            String   @unique
  email            String   @unique
  address          String
  passwordHash     String
  codeHash         String
  pendingTokenHash String?  @unique
  expiresAt        DateTime
  attempts         Int      @default(0)
  lastSentAt       DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([expiresAt])
}

model PendingUserSignup {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  nickname         String   @unique
  phone            String   @unique
  email            String   @unique
  passwordHash     String
  codeHash         String
  pendingTokenHash String?  @unique
  expiresAt        DateTime
  attempts         Int      @default(0)
  lastSentAt       DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([expiresAt])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  places Place[]

  @@index([isActive, sortOrder])
}

model Place {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  categoryId  String
  city        String
  region      String?
  address     String?
  lat         Float?
  lng         Float?
  phone       String?
  website     String?
  companyId   String?
  workHours   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  avgRating   Float @default(0)
  ratingCount Int   @default(0)

  company  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  reviews  Review[]
  claims   Claim[]

  @@index([categoryId])
  @@index([city])
  @@index([companyId])
}

model Tag {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  reviewTags ReviewTag[]

  @@index([isActive, sortOrder])
}

model Review {
  id         String       @id @default(cuid())
  placeId    String
  authorId   String
  rating     Int
  text       String
  status     ReviewStatus @default(PUBLISHED)
  isVerified Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  place   Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags    ReviewTag[]
  replies ReviewReply[]

  @@index([placeId])
  @@index([authorId])
  @@index([createdAt])
  @@unique([placeId, authorId])
}

model ReviewTag {
  reviewId String
  tagId    String

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reviewId, tagId])
  @@index([tagId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  companyId String
  text      String
  createdAt DateTime @default(now())

  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([companyId])
  @@unique([reviewId, companyId])
}

model Claim {
  id        String      @id @default(cuid())
  placeId   String
  companyId String
  status    ClaimStatus @default(PENDING)
  message   String?
  createdAt DateTime    @default(now())

  place   Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@index([companyId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([email])
  @@index([expiresAt])
}

model RateLimitBucket {
  id              String   @id @default(cuid())
  scope           String
  keyHash         String
  hits            Int      @default(0)
  windowStartedAt DateTime
  windowExpiresAt DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([scope, keyHash])
  @@index([windowExpiresAt])
}